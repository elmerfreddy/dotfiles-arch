# ============================================
# Git - Configuración básica
# ============================================
# Datos personales en ~/.gitconfig.local
# Crea el archivo con:
#   [user]
#       name = Tu Nombre
#       email = tu@email.com

[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[core]
    editor = nvim
    autocrlf = input
    pager = less -FRX
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[pull]
    rebase = false

[push]
    default = current
    autoSetupRemote = true

[merge]
    conflictstyle = diff3
    tool = nvim

[diff]
    colorMoved = default

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    cm = commit -m
    ca = commit --amend
    lg = log --oneline --graph --decorate --all
    last = log -1 HEAD
    unstage = reset HEAD --
    undo = reset --soft HEAD~1
    wip = !git add -A && git commit -m 'WIP'
    aliases = config --get-regexp alias

[credential]
    helper = cache
